{
  "version": 2,
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://ai-generated-check.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/pic/:path*",
      "destination": "/api/pic?slug=:path*"
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 15
    },
    "api/pic.js": {
      "maxDuration": 10
    }
  }
}
